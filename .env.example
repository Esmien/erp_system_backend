# Настройка места хранения docker-compose
COMPOSE_FILE=infra/docker-compose.yml

# Параметры подключения к БД
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=business_management
DB_HOST=db
DB_PORT=5432

# Настройки Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Настройки инвайт-кода для вступления в команду
CODE_LENGTH=6

# Настройки JWT
SECRET_KEY=
ALGORYTHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30